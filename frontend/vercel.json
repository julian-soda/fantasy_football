{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://REPLACE_WITH_APP_RUNNER_URL/api/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://REPLACE_WITH_APP_RUNNER_URL/auth/:path*"
    },
    {
      "source": "/((?!api|auth).*)",
      "destination": "/index.html"
    }
  ]
}
