{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://mfsarzpx7y.us-east-1.awsapprunner.com/api/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://mfsarzpx7y.us-east-1.awsapprunner.com/auth/:path*"
    },
    {
      "source": "/((?!api|auth).*)",
      "destination": "/index.html"
    }
  ]
}
